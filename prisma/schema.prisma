generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(VIEWER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  entries      Entry[]  @relation("CreatedBy")
}

model Entry {
  id             String   @id @default(cuid())
  portfolio      String
  project        String
  task           String
  folderLink     String?
  adminPanelLink String?
  titleId        String?
  kpId           String?
  figmaLink      String?
  sourceLink     String?
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String
  createdBy      User     @relation("CreatedBy", fields: [createdById], references: [id])

  @@index([portfolio])
  @@index([project])
  @@index([titleId])
  @@index([kpId])
}
