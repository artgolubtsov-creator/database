generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  SUPER_EDITOR
  CONTENT_EDITOR
  OFFER_MANAGER
  EDITOR       // legacy — maps to CONTENT_EDITOR
  VIEWER
}

enum ContentType {
  EXCLUSIVE
  MOVIES
  SERIES
  ORIGINAL
}

enum MaterialStatus {
  ADDED
  NOT_RECEIVED_YET
  NOT_REQUIRED
  REQUEST_FROM_OTT
}

enum BrandCategory {
  GUIDE
  LOGO
  PRESENTATION
  ACTIVE_OFFER
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  passwordHash   String
  role           Role            @default(VIEWER)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  entries        Entry[]         @relation("CreatedBy")
  brandMaterials BrandMaterial[] @relation("CreatedBrandMaterials")
  offerRecords   OfferRecord[]   @relation("CreatedOffers")
}

model Entry {
  id          String  @id @default(cuid())

  titleName   String
  contentType ContentType?
  description String?

  portfolio   String
  project     String

  titleId     String?
  kpId        String?

  folderLink            String?
  adminPanelLink        String?
  figmaLink             String?
  sourceLink            String?
  performanceCopiesLink String?
  digitalCopiesLink     String?
  copyDeckLink          String?

  arabicTitle          String?
  arabicDescription    String?
  arabicShortCopy      String?
  arabicMarketingCopy  String?
  arabicNotes          String?

  rightholder    String?
  year           Int?
  restrictionAge String?
  genres         String?
  countries      String?

  mainPosterStatus        MaterialStatus?
  characterPostersStatus  MaterialStatus?
  trailerStatus           MaterialStatus?
  teaserStatus            MaterialStatus?
  episodesStatus          MaterialStatus?
  highlightsNotes         String?

  shareToken  String   @unique @default(cuid())

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation("CreatedBy", fields: [createdById], references: [id])

  @@index([portfolio])
  @@index([project])
  @@index([titleId])
  @@index([kpId])
  @@index([contentType])
}

model OfferRecord {
  id           String   @id @default(cuid())
  type         String   // future | current | old
  offerKind    String?  // Main product | Performance | Trial | Promo
  date         String?  // planned change date (future offers only)
  country      String
  tariff       String   // Basic | Premium | Crunchyroll
  platform     String   // iOS | Android | Native
  offerName    String
  offerValue   String?
  price        String?
  duration     String?
  promoCode    String?
  description  String?
  source       String   @default("Manual")
  dateFrom     String?
  dateTo       String?
  comment      String?
  status       String?
  buttonTextEn String?
  buttonTextAr String?
  disclaimerEn String?
  disclaimerAr String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdById  String
  createdBy    User     @relation("CreatedOffers", fields: [createdById], references: [id])

  @@index([type])
  @@index([country])
}

model BrandMaterial {
  id          String        @id @default(cuid())
  title       String
  description String?
  link        String?
  category    BrandCategory
  owner       String?
  isPublic    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdById String
  createdBy   User          @relation("CreatedBrandMaterials", fields: [createdById], references: [id])

  @@index([category])
}
