generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  VIEWER
}

enum ContentType {
  EXCLUSIVE
  MOVIES
  SERIES
  ORIGINAL
}

enum MaterialStatus {
  ADDED
  NOT_RECEIVED_YET
  NOT_REQUIRED
  REQUEST_FROM_OTT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(VIEWER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  entries      Entry[]  @relation("CreatedBy")
}

model Entry {
  id          String  @id @default(cuid())

  // Basic info
  titleName   String
  contentType ContentType?
  description String?

  // Portfolio / Project links
  portfolio   String
  project     String

  // IDs
  titleId     String?
  kpId        String?

  // Links
  folderLink            String?
  adminPanelLink        String?
  figmaLink             String?
  sourceLink            String?
  performanceCopiesLink String?
  digitalCopiesLink     String?
  copyDeckLink          String?

  // Arabic texts
  arabicTitle          String?
  arabicDescription    String?
  arabicShortCopy      String?
  arabicMarketingCopy  String?
  arabicNotes          String?

  // Title metadata
  rightholder    String?
  year           Int?
  restrictionAge String?
  genres         String?
  countries      String?

  // Highlights material
  mainPosterStatus        MaterialStatus?
  characterPostersStatus  MaterialStatus?
  trailerStatus           MaterialStatus?
  teaserStatus            MaterialStatus?
  episodesStatus          MaterialStatus?
  highlightsNotes         String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation("CreatedBy", fields: [createdById], references: [id])

  @@index([portfolio])
  @@index([project])
  @@index([titleId])
  @@index([kpId])
  @@index([contentType])
}
