generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum ContentType {
  EXCLUSIVE
  MOVIES
  SERIES
  ORIGINAL
}

enum MaterialStatus {
  ADDED
  NOT_RECEIVED_YET
  NOT_REQUIRED
  REQUEST_FROM_OTT
}

enum BrandCategory {
  GUIDE
  LOGO
  PRESENTATION
  ACTIVE_OFFER
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  passwordHash   String
  role           Role            @default(VIEWER)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  entries        Entry[]         @relation("CreatedBy")
  brandMaterials BrandMaterial[] @relation("CreatedBrandMaterials")
}

model Entry {
  id          String  @id @default(cuid())

  titleName   String
  contentType ContentType?
  description String?

  portfolio   String
  project     String

  titleId     String?
  kpId        String?

  folderLink            String?
  adminPanelLink        String?
  figmaLink             String?
  sourceLink            String?
  performanceCopiesLink String?
  digitalCopiesLink     String?
  copyDeckLink          String?

  arabicTitle          String?
  arabicDescription    String?
  arabicShortCopy      String?
  arabicMarketingCopy  String?
  arabicNotes          String?

  rightholder    String?
  year           Int?
  restrictionAge String?
  genres         String?
  countries      String?

  mainPosterStatus        MaterialStatus?
  characterPostersStatus  MaterialStatus?
  trailerStatus           MaterialStatus?
  teaserStatus            MaterialStatus?
  episodesStatus          MaterialStatus?
  highlightsNotes         String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String
  createdBy   User     @relation("CreatedBy", fields: [createdById], references: [id])

  @@index([portfolio])
  @@index([project])
  @@index([titleId])
  @@index([kpId])
  @@index([contentType])
}

model BrandMaterial {
  id          String        @id @default(cuid())
  title       String
  description String?
  link        String?
  category    BrandCategory
  owner       String?
  isPublic    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdById String
  createdBy   User          @relation("CreatedBrandMaterials", fields: [createdById], references: [id])

  @@index([category])
}
